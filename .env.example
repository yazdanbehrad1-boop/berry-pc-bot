# ── Groq (LLM — free tier) ────────────────────────────────────────────────────
# Sign up at https://console.groq.com → API Keys
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# ── Voyage AI (Embeddings — free tier: 200M tokens/month) ────────────────────
# Sign up at https://dash.voyageai.com → API Keys
VOYAGE_API_KEY=pa-...
VOYAGE_MODEL=voyage-3-lite

# ── Supabase (Database — free tier) ──────────────────────────────────────────
# Your project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Telegram (optional) ───────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=1234567890:ABC...
# Public URL where this server is reachable (needed for webhook registration)
WEBHOOK_BASE_URL=https://your-domain.com

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── RAG tuning ────────────────────────────────────────────────────────────────
RAG_MATCH_THRESHOLD=0.65
RAG_MATCH_COUNT=5

# ── Memory tuning ────────────────────────────────────────────────────────────
SHORT_TERM_WINDOW=12
LONG_TERM_FETCH=6
